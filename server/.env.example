# ============================================================
# Realtime Antrian Python - Server Environment Configuration
# ============================================================
# Salin file ini menjadi .env dan sesuaikan nilainya:
#   cp .env.example .env

# ------------------------------------------------------------
# MySQL Database Configuration
# ------------------------------------------------------------

# Host database MySQL (gunakan 'mysql' jika pakai Docker Compose)
DB_HOST=127.0.0.1

# Port database MySQL
DB_PORT=3306

# Username database
DB_USER=antrian_user

# Password database
DB_PASS=antrian_pass

# Nama database
DB_NAME=antrian_db

# ------------------------------------------------------------
# MySQL Docker Service (digunakan oleh docker-compose.yml)
# ------------------------------------------------------------

# Password root MySQL
MYSQL_ROOT_PASSWORD=rootpassword

# Nama database yang dibuat otomatis saat container pertama kali berjalan
MYSQL_DATABASE=antrian_db

# Username MySQL non-root
MYSQL_USER=antrian_user

# Password MySQL non-root
MYSQL_PASSWORD=antrian_pass

# Port MySQL yang di-expose ke host
MYSQL_PORT=3306

# ------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------

# Port FastAPI backend server
SERVER_PORT=8000

# Port React frontend client
CLIENT_PORT=3000
