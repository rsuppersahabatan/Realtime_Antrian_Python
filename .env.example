# ============================================================
# Realtime Antrian Python - Root Environment Configuration
# ============================================================
# Salin file ini menjadi .env dan sesuaikan nilainya:
#   cp .env.example .env
#
# File ini digunakan bersama docker-compose.yml dan Dockerfile
# untuk mengkonfigurasi service MySQL, Backend, dan Frontend.
# ============================================================

# ------------------------------------------------------------
# MySQL Database Configuration (untuk service mysql)
# ------------------------------------------------------------

# Password root MySQL
MYSQL_ROOT_PASSWORD=rootpassword

# Nama database yang dibuat otomatis saat container pertama kali berjalan
MYSQL_DATABASE=antrian_db

# Username MySQL non-root
MYSQL_USER=antrian_user

# Password MySQL non-root
MYSQL_PASSWORD=antrian_pass

# Port MySQL yang di-expose ke host (default: 3306)
MYSQL_PORT=3306

# ------------------------------------------------------------
# MySQL Connection (untuk koneksi dari aplikasi backend)
# ------------------------------------------------------------

# Host database MySQL (gunakan 'mysql' jika pakai Docker Compose,
# atau '127.0.0.1' / 'localhost' jika running manual)
DB_HOST=mysql

# Port database MySQL
DB_PORT=3306

# Username database
DB_USER=antrian_user

# Password database
DB_PASS=antrian_pass

# Nama database
DB_NAME=antrian_db

# ------------------------------------------------------------
# Server Configuration (untuk service backend & frontend)
# ------------------------------------------------------------

# Port FastAPI/backend server (default: 8000)
SERVER_PORT=8000

# Port React/frontend client (default: 3000)
CLIENT_PORT=3000