# ============================================================
# Realtime Antrian Python - Root Environment Configuration
# ============================================================
# Salin file ini menjadi .env dan sesuaikan nilainya:
#   cp .env.example .env
#
# File ini digunakan oleh docker-compose.yml dan seluruh service.
# Setiap perubahan environment variable harus diikuti rebuild container.
# ============================================================

# ------------------------------------------------------------
# MySQL Database Configuration
# ------------------------------------------------------------
# Variabel-variabel ini digunakan oleh service `mysql`
# dan juga dibaca oleh backend Python untuk koneksi database.

# Host database MySQL.
# Gunakan 'mysql' jika berjalan di dalam Docker Compose network,
# atau '127.0.0.1' / 'localhost' jika backend berjalan di host langsung.
MYSQL_HOST=mysql

# Port MySQL di dalam container (jangan diubah kecuali custom image)
MYSQL_PORT=3306

# Password untuk user root MySQL
MYSQL_ROOT_PASSWORD=rootpassword

# Nama database yang akan dibuat otomatis saat container pertama kali jalan
MYSQL_DATABASE=antrian_db

# Username MySQL non-root untuk koneksi aplikasi
MYSQL_USER=antrian_user

# Password untuk user MySQL non-root di atas
MYSQL_PASSWORD=antrian_pass

# ------------------------------------------------------------
# Backend (Python FastAPI) - Database Connection
# ------------------------------------------------------------
# Variabel ini dibaca oleh server/config/database.py
# untuk koneksi ke MySQL dari sisi Python backend.

DB_HOST=${MYSQL_HOST}
DB_PORT=${MYSQL_PORT}
DB_USER=${MYSQL_USER}
DB_PASS=${MYSQL_PASSWORD}
DB_NAME=${MYSQL_DATABASE}

# ------------------------------------------------------------
# Backend (Python FastAPI) - Server Port
# ------------------------------------------------------------
# Port yang digunakan oleh FastAPI server di dalam container.
# SERVER_PORT memetakan ke port 8000 container -> port host.
SERVER_PORT=8000

# ------------------------------------------------------------
# Frontend Client (React Vite / TanStack Start SSR)
# ------------------------------------------------------------
# Port yang digunakan oleh frontend SSR di dalam container.
# CLIENT_PORT memetakan ke port 3000 container -> port host.
CLIENT_PORT=3000

# Port internal untuk Node.js SSR server (dibaca langsung oleh dist/server/server.js).
# Nilai ini harus sesuai dengan port yang di-EXPOSE di client/Dockerfile.
PORT=3000

# URL Base untuk koneksi frontend ke backend API.
# Saat jalan di Docker Compose, gunakan nama service 'backend'.
# Saat development lokal tanpa Docker, gunakan http://localhost:8000
VITE_API_URL=http://backend:8000

# Node environment. Sudah di-set otomatis di client/Dockerfile,
# tetapi bisa di-override jika diperlukan.
# NODE_ENV=production